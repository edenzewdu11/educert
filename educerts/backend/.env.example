# EduCerts backend environment variables
# Copy to .env for local dev, or set these in Render (Environment tab).

# Postgres connection string (Render Postgres "Internal Database URL").
# Leave unset locally to fall back to SQLite (educerts.db).
DATABASE_URL=

# JWT signing secret - use a long random string in production.
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Set to "production" on Render so cookies are Secure + SameSite=None.
ENVIRONMENT=production

# Frontend origin(s) allowed by CORS. Comma-separated for multiple.
# e.g. https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# Ed25519 issuer private key (PEM). Set in production so the signing key is
# stable across redeploys. Paste the full PEM including BEGIN/END lines.
ISSUER_PRIVATE_KEY=
